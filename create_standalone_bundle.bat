echo WshShell.Run "elara_pos.exe", 1, True >> "%APP_DIR%\START_POS.vbs"

:: ── LAUNCHER.bat ───────────────────────────────────────────
echo @echo off > "%APP_DIR%\LAUNCHER.bat"
echo echo ================================================= >> "%APP_DIR%\LAUNCHER.bat"
echo echo   Elara POS Launcher (with Elais AI) >> "%APP_DIR%\LAUNCHER.bat"
echo echo ================================================= >> "%APP_DIR%\LAUNCHER.bat"
echo echo. >> "%APP_DIR%\LAUNCHER.bat"
echo. >> "%APP_DIR%\LAUNCHER.bat"
echo :: ── OLLAMA CHECK ─────────────────────────────────── >> "%APP_DIR%\LAUNCHER.bat"
echo set OLLAMA_FOUND=0 >> "%APP_DIR%\LAUNCHER.bat"
echo where ollama ^>nul 2^>^&1 ^&^& set OLLAMA_FOUND=1 >> "%APP_DIR%\LAUNCHER.bat"
echo if exist "%%LOCALAPPDATA%%\Programs\Ollama\ollama.exe" set OLLAMA_FOUND=1 >> "%APP_DIR%\LAUNCHER.bat"
echo. >> "%APP_DIR%\LAUNCHER.bat"
echo if %%OLLAMA_FOUND%%==0 ( >> "%APP_DIR%\LAUNCHER.bat"
echo     echo [Elais] Ollama is NOT installed on this PC. >> "%APP_DIR%\LAUNCHER.bat"
echo     echo. >> "%APP_DIR%\LAUNCHER.bat"
echo     choice /C YN /M "Would you like to automatically download and install Ollama now?" >> "%APP_DIR%\LAUNCHER.bat"
echo     if %%ERRORLEVEL%%==1 ( >> "%APP_DIR%\LAUNCHER.bat"
echo         echo. >> "%APP_DIR%\LAUNCHER.bat"
echo         echo [Elais] Downloading Ollama installer... >> "%APP_DIR%\LAUNCHER.bat"
echo         powershell -Command "Invoke-WebRequest -Uri 'https://ollama.com/download/OllamaSetup.exe' -OutFile '%%TEMP%%\OllamaSetup.exe' -UseBasicParsing" >> "%APP_DIR%\LAUNCHER.bat"
echo         if exist "%%TEMP%%\OllamaSetup.exe" ( >> "%APP_DIR%\LAUNCHER.bat"
echo             echo [Elais] Installing Ollama silently... >> "%APP_DIR%\LAUNCHER.bat"
echo             "%%TEMP%%\OllamaSetup.exe" /SILENT >> "%APP_DIR%\LAUNCHER.bat"
echo             timeout /t 5 /nobreak ^>nul >> "%APP_DIR%\LAUNCHER.bat"
echo             echo. >> "%APP_DIR%\LAUNCHER.bat"
echo             choice /C YN /M "Ollama installed! Download AI model now (phi3:mini, approx 2.3GB)?" >> "%APP_DIR%\LAUNCHER.bat"
echo             if %%ERRORLEVEL%%==1 ( >> "%APP_DIR%\LAUNCHER.bat"
echo                 echo [Elais] Downloading phi3:mini model... >> "%APP_DIR%\LAUNCHER.bat"
echo                 ollama pull phi3:mini >> "%APP_DIR%\LAUNCHER.bat"
echo                 powershell -Command "[Environment]::SetEnvironmentVariable('PATH', [Environment]::GetEnvironmentVariable('PATH','Machine') + ';%%LOCALAPPDATA%%\Programs\Ollama', 'Machine')" >> "%APP_DIR%\LAUNCHER.bat"
echo                 echo [Elais] Starting Ollama service... >> "%APP_DIR%\LAUNCHER.bat"
echo                 start /min cmd /c "ollama serve" >> "%APP_DIR%\LAUNCHER.bat"
echo                 timeout /t 3 /nobreak ^>nul >> "%APP_DIR%\LAUNCHER.bat"
echo                 echo [Elais] AI is ready! >> "%APP_DIR%\LAUNCHER.bat"
echo             ) else ( >> "%APP_DIR%\LAUNCHER.bat"
echo                 echo [Elais] Model skipped. Run "ollama pull phi3:mini" later to enable AI. >> "%APP_DIR%\LAUNCHER.bat"

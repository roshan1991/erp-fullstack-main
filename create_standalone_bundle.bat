echo         ) else ( >> "%APP_DIR%\LAUNCHER.bat"
echo             echo [Elais] Download failed. Check your internet and try again. >> "%APP_DIR%\LAUNCHER.bat"
echo         ) >> "%APP_DIR%\LAUNCHER.bat"
echo     ) else ( >> "%APP_DIR%\LAUNCHER.bat"
echo         echo. >> "%APP_DIR%\LAUNCHER.bat"
echo         echo [Elais] No problem! Two ways to set up AI later: >> "%APP_DIR%\LAUNCHER.bat"
echo         echo. >> "%APP_DIR%\LAUNCHER.bat"
echo         echo   OPTION 1 - Install Ollama manually: >> "%APP_DIR%\LAUNCHER.bat"
echo         echo     1. Go to https://ollama.com/download >> "%APP_DIR%\LAUNCHER.bat"
echo         echo     2. Run OllamaSetup.exe >> "%APP_DIR%\LAUNCHER.bat"
echo         echo     3. Open terminal and run: ollama pull phi3:mini >> "%APP_DIR%\LAUNCHER.bat"
echo         echo     4. Restart ElaraPOS >> "%APP_DIR%\LAUNCHER.bat"

echo if %%ERRORLEVEL%% NEQ 0 ( >> "%APP_DIR%\LAUNCHER.bat"
echo     echo Starting XAMPP MySQL... >> "%APP_DIR%\LAUNCHER.bat"
echo     start "" "C:\xampp\mysql\bin\mysqld.exe" --port=3306 >> "%APP_DIR%\LAUNCHER.bat"

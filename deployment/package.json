{
    "name": "erp-fullstack",
    "version": "1.0.0",
    "description": "Full-stack ERP System - Frontend + Backend combined",
    "main": "server.js",
    "scripts": {
        "install-all": "npm install && cd client && npm install && cd ..",
        "build": "cd client && npm run build && cd ..",
        "start": "node server.js",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "server": "nodemon server.js",
        "client": "cd client && npm run dev",
        "create-admin": "node scripts/create_admin.js",
        "sync-db": "node scripts/sync_database.js",
        "reset-db": "node scripts/reset_database.js"
    },
    "keywords": [
        "erp",
        "fullstack",
        "express",
        "react"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "mysql2": "^3.9.7",
        "sequelize": "^6.37.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0"
    },
    "devDependencies": {
        "baseline-browser-mapping": "^2.9.19",
        "concurrently": "^8.2.2",
        "nodemon": "^3.1.0"
    }
}
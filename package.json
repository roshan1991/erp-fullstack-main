{
    "name": "erp-fullstack",
    "version": "1.0.0",
    "description": "Full-stack ERP System - Frontend + Backend combined",
    "main": "server.js",
    "scripts": {
        "install-all": "npm install && cd client && npm install && cd ..",
        "build": "cd client && npm run build && cd ..",
        "start": "node server.js",
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "server": "nodemon server.js",
        "client": "cd client && npm run dev",
        "create-admin": "node scripts/create_admin.js",
        "sync-db": "node scripts/sync_database.js",
        "reset-db": "node scripts/reset_db_and_seed.js",
        "wa-sim": "node scripts/wa_simulator.js"
    },
    "keywords": [
        "erp",
        "fullstack",
        "express",
        "react"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@react-native-async-storage/async-storage": "^2.2.0",
        "@react-navigation/bottom-tabs": "^7.14.0",
        "@react-navigation/native": "^7.1.28",
        "@react-navigation/native-stack": "^7.13.0",
        "axios": "^1.13.5",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "mysql2": "^3.9.7",
        "react-native-chart-kit": "^6.12.0",
        "react-native-safe-area-context": "^5.6.2",
        "react-native-screens": "^4.23.0",
        "react-native-svg": "^15.15.3",
        "react-native-vector-icons": "^10.3.0",
        "sequelize": "^6.37.3",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "better-sqlite3": "^11.0.0"
    },
    "devDependencies": {
        "baseline-browser-mapping": "^2.9.19",
        "concurrently": "^8.2.2",
        "nodemon": "^3.1.0"
    }
}